{
    "extends": "@growthos/tsconfig/nestjs.json",
    "compilerOptions": {
        "allowJs": true,
        "baseUrl": "src",
        "esModuleInterop": true,
        "incremental": false,
        "outDir": "dist",
        "noEmit": true
    },
    "include": ["src"],
    "exclude": ["node_modules", "test", "dist", "**/*spec.ts"]
}
